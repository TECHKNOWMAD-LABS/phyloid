{
  "name": "phyloid",
  "version": "0.1.0",
  "description": "3D WebGL evolution simulator — fitness-mapped phylogenetic organisms via Three.js",
  "type": "module",
  "author": "TechKnowMad Labs <admin@techknowmad.ai>",
  "homepage": "https://github.com/TECHKNOWMAD-LABS/phyloid",
  "repository": {
    "type": "git",
    "url": "https://github.com/TECHKNOWMAD-LABS/phyloid.git"
  },
  "bugs": {
    "url": "https://github.com/TECHKNOWMAD-LABS/phyloid/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "security": "node scripts/security-scan.mjs",
    "format": "prettier --write src/ tests/ 2>/dev/null || true",
    "clean": "rm -rf dist coverage node_modules/.cache"
  },
  "keywords": [
    "3d",
    "threejs",
    "phyloid",
    "fitness",
    "generative"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stripe/stripe-js": "^8.11.0",
    "@types/three": "^0.128.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^10.1.0",
    "fast-check": "^4.6.0",
    "jsdom": "^24.1.3",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.57.1",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.0",
    "three": "0.128.0"
  }
}
